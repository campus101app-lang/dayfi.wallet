// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  username     String  @unique
  isVerified   Boolean @default(false)

  // OTP
  otpCode      String?
  otpExpiry    DateTime?
  otpAttempts  Int     @default(0)

  // ── Stellar wallet (XLM, USDC, BTC on Stellar, GOLD on Stellar) ──────────
  stellarPublicKey  String? @unique
  stellarSecretKey  String? // AES-256-GCM encrypted

  // ── EVM wallet (ETH, Arbitrum, Polygon, Avalanche — same address) ─────────
  // Supports: USDC on ETH/ARB/POLY/AVAX, XAU₮ (Tether Gold) on ETH
  evmPublicKey  String? @unique
  evmSecretKey  String? // AES-256-GCM encrypted

  // ── Bitcoin wallet (native BTC) ───────────────────────────────────────────
  btcPublicKey  String? @unique
  btcSecretKey  String? // AES-256-GCM encrypted (WIF format)

  // ── Solana wallet (USDC on Solana) ────────────────────────────────────────
  solanaPublicKey  String? @unique
  solanaSecretKey  String? // AES-256-GCM encrypted

  // Biometric
  faceIdEnabled Boolean @default(false)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?

  // Relations
  transactions Transaction[]
  deviceTokens DeviceToken[]

  @@index([email])
  @@index([username])
  @@index([stellarPublicKey])
  @@index([evmPublicKey])
  @@index([btcPublicKey])
  @@index([solanaPublicKey])
}

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   TransactionType
  status TransactionStatus @default(pending)

  amount Float
  asset  String // USDC | XLM | BTC | GOLD | ETH | SOL

  // Network identifier: stellar | ethereum | arbitrum | polygon | avalanche | bitcoin | solana
  network String @default("stellar")

  fromAddress  String?
  toAddress    String?
  toUsername   String? // @dayfi.me username if internal transfer

  // Chain-specific tx hashes
  stellarTxHash  String? @unique
  evmTxHash      String? @unique
  btcTxHash      String? @unique
  solanaTxHash   String? @unique

  memo String?
  fee  Float?

  // Swap metadata (if this tx is part of a swap)
  isSwap        Boolean @default(false)
  swapFromAsset String?
  swapToAsset   String?
  swapQuoteId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([network])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // ios | android
  createdAt DateTime @default(now())

  @@index([userId])
}

enum TransactionType {
  send
  receive
  swap
}

enum TransactionStatus {
  pending
  confirmed
  failed
}
